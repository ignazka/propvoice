{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev"],
      "port": 3000
    },
    {
      "name": "Backend (FastAPI)",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["main:app", "--reload", "--app-dir", "backend"],
      "port": 8000
    },
    {
      "name": "Agent (LiveKit)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["backend/agent.py", "dev"],
      "port": 8001,
      "autoPort": true
    }
  ]
}
